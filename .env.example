''' -------------- Base Configuration -------------- '''
# [OPTIONAL] Redis Configuration
# For local development, you can leave these commented out to use defaults
# REDIS_HOST=localhost      # Redis server host
# REDIS_PORT=6379          # Redis server port
# REDIS_DB=0              # Redis database number
# REDIS_PASSWORD=         # Redis password (if required)
# REDIS_SSL=false         # Whether to use SSL for Redis connection

# [OPTIONAL] AWS credential profile selection
# If credentials are set here, they take precedence over profile. 
AWS_PROFILE=your_profile_name

# S3 bucket for data ingestion
S3_INGESTION_BUCKET=ingestion-prod-ap-southeast-2-5cbf3af13db996eb

# [OPTIONAL] S3 bucket for audit trail and control-plane Delta tables (api_requests, api_responses)
# S3_CONTROL_BUCKET=control-prod-ap-southeast-2-xxx

# [OPTIONAL] Databricks connection
DATABRICKS_HOST=your-host
DATABRICKS_CLIENT_ID=your-id
DATABRICKS_CLIENT_SECRET=your-secret
DATABRICKS_WAREHOUSE_ID=your-warehouse-id

''' -------------- API Credentials -------------- '''
# API Settings
ROUNDEL_API_KEY_PROD=your-api-key
ROUNDEL_API_OAUTH_CLIENT_ID=your-client-id
ROUNDEL_API_OAUTH_CLIENT_SECRET=your-client-secret
ROUNDEL_API_OAUTH_ISSUER=your-issuer
ROUNDEL_API_PRIVATE_KEY_BASE64=your-base64-encoded-private-key

# Walmart Connect API Settings
# For multiple IDs use a JSON array (no spaces after commas to avoid .env quirks):
# WMC_SEARCH_ADVERTISER_IDS=["219880","426051"]
WMC_SEARCH_ADVERTISER_IDS=your-advertiser-id-list
WMC_DISPLAY_ADVERTISER_IDS=your-advertiser-id-list
WMC_CONSUMER_ID=your-consumer-id
WMC_API_BEARER_TOKEN=your-bearer-token
WMC_API_PRIVATE_KEY_BASE64=your-base64-encoded-private-key

# Walmart Data Feed API Settings
WNRT_CONSUMER_ID=your-consumer-id
WNRT_API_PRIVATE_KEY_BASE64=your-base64-encoded-private-key

APIFY_API_TOKEN=your_apify_api_token_here

# TIKTOK DISCOVERY KEYS 
TIKTOK_API_KEY = the-tiktok-business-key
TIKTOK_ADVERTISER_ID = the-tiktok-advertiser-id

# TikTok One / TCM:
TTO_TCM_ACCOUNT_ID=your_tto_tcm_account_id_here

# TIKTOK CML KEYS  (Via TikTok App Credentials) 
TIKTOK_APP_ID=your_tiktok_app_id_here
TIKTOK_APP_SECRET=your_tiktok_app_secret_here

# These keys are associated with MONDAY HAIRCARE, to gain access to creator data.
# expires every day - but refreshes in framework with the refresh token 
TIKTOK_ACCOUNT_ACCESS_TOKEN=your_tiktok_account_access_token_here
# expires once a year 
TIKTOK_ACCOUNT_REFRESH_TOKEN=your_tiktok_account_refresh_token_here
# never expires - permanent identifier 
TIKTOK_ACCOUNT_OPEN_ID=your_tiktok_account_open_id_here

# WEATHERSTACK SALESOPS API KEY
WEATHERSTACK_API_KEY=your_weatherstack_api_key_here

# Linkedin API key
LINKEDIN_API_ACCESS_KEY=your_linkedin_api_key_here
LINKEDIN_API_VERSION=YOUR_LINKEDIN_API_VERSION_HERE

# UNIS LOGISTICS
UNIS_LOGISTICS_USERNAME=your_unis_logistics_username
UNIS_LOGISTICS_PASSWORD=your_unis_logistics_password

# Hive connection
HIVE_API_KEY=your_hive_api_key_here
HIVE_WORKSPACE_ID=your_worspace_id_here
HIVE_PROJECT_ID=your_project_id

# Google Ads
GOOGLE_ADS_CLIENT_EMAIL=your-client-email
GOOGLE_ADS_PRIVATE_KEY_BASE64=your-private-key
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token
GOOGLE_ADS_LOGIN_CUSTOMER_ID=your-login-customer-id

# -------------- Secret redaction (Spine logger) --------------
# Spine redacts sensitive data in logs (extra_fields, message key=value, exceptions).
# Built-in redaction already covers keys containing: PASSWORD, SECRET, TOKEN, API_KEY, CREDENTIAL, PRIVATE, JWT, OIDC, BEARER.
# Set SPINE_SENSITIVE_KEYS to redact additional env/key names that are not in the built-in set (no spaces after commas).

# [OPTIONAL] Set to false, 0, or no to disable redaction (e.g. for local debugging). Default: redaction enabled.
# SPINE_REDACT_LOGS=true

# [OPTIONAL] Comma-separated list of additional key names to treat as sensitive (merged with built-in set).
# SPINE_SENSITIVE_KEYS=DATABRICKS_CLIENT_ID,UNIS_LOGISTICS_USERNAME,ROUNDEL_API_OAUTH_CLIENT_ID,ROUNDEL_API_OAUTH_ISSUER,WMC_CONSUMER_ID,WNRT_CONSUMER_ID,TIKTOK_APP_ID,TIKTOK_ADVERTISER_ID,TIKTOK_ACCOUNT_OPEN_ID,GOOGLE_ADS_CLIENT_EMAIL,GOOGLE_ADS_LOGIN_CUSTOMER_ID
