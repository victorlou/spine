# ---------------------------------------------------------------------------
# Spine — environment template
# Copy to `.env` at the repository root and adjust values.
# Variables used at runtime are whatever your `config/` YAML references via
# ${VAR_NAME} or defaults from `config/defaults.example.yml` (e.g. S3, Redis).
# ---------------------------------------------------------------------------

# --- Core / platform (common) ---

# [OPTIONAL] Redis (defaults suit local Docker Compose / localhost)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=
# REDIS_SSL=false

# AWS: profile or standard env vars (see boto3 / your cloud setup)
AWS_PROFILE=your-aws-profile

# Bucket for pipeline writes (must match loading defaults in `config/defaults.yml`)
S3_INGESTION_BUCKET=your-ingestion-bucket-name

# Promote local operator config to S3 (one-off / CI):
#   python -m src.utils.s3_config_push s3://your-bucket/your-prefix/
# [OPTIONAL] ECS/Fargate: pull operator config from S3 before the app starts (boto3 in
# docker/startup.sh; no AWS CLI). Target is CONFIG_PATH if set, else /app/config.
# SPINE_CONFIG_S3_URI=s3://your-bucket/your-prefix/config/
# See docs/deployment/ecs-s3-reference.md

# [OPTIONAL] Separate bucket for audit / control-plane tables if you use that layout
# S3_CONTROL_BUCKET=your-control-bucket-name

# --- Databricks (optional; only if sources use Databricks) ---

# DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
# DATABRICKS_CLIENT_ID=your-service-principal-client-id
# DATABRICKS_CLIENT_SECRET=your-service-principal-secret
# DATABRICKS_WAREHOUSE_ID=your-warehouse-id

# --- Relational source example (see `config/examples/postgres.example.yml`) ---

# PG_HOST=localhost
# PG_USER=your_db_user
# PG_PASSWORD=your_db_password
# PG_DATABASE=your_db_name

# --- REST / vendor APIs ---

# Define only what your own `config/sources/*.yml` files reference, for example:
# MY_API_BASE_TOKEN=...
# OAUTH_CLIENT_ID=...
# OAUTH_CLIENT_SECRET=...

# --- Secret redaction (Spine logger) ---

# Spine redacts sensitive data in logs (extra_fields, message key=value, exceptions).
# Built-in redaction covers keys whose names suggest secrets (PASSWORD, TOKEN, etc.).
# Add more names (as they appear in logs / extra_fields) with SPINE_SENSITIVE_KEYS.

# [OPTIONAL] Set to false, 0, or no to disable redaction (e.g. local debugging).
# SPINE_REDACT_LOGS=true

# [OPTIONAL] Comma-separated extra sensitive key names (no spaces after commas).
# SPINE_SENSITIVE_KEYS=MY_PARTNER_ID,INTERNAL_ACCOUNT_REF
